# ============================================================
# NODE
# ============================================================

# All installed packages — never push this to GitHub
# Anyone who clones the repo just runs "npm install" to get these back
node_modules/

# npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ============================================================
# CYPRESS GENERATED FILES
# ============================================================

# Videos recorded during test runs — large files, not needed in repo
cypress/videos/

# Screenshots taken when a test fails — not needed in repo
cypress/screenshots/

# Cypress download folder for any downloaded files during tests
cypress/downloads/


# ============================================================
# TEST REPORTS
# ============================================================

# Mochawesome HTML/JSON reports (if you add reporting later)
cypress/reports/
mochawesome-report/


# ============================================================
# ENVIRONMENT & SECRETS
# ============================================================

# Environment variable files — NEVER push these, they may contain passwords/API keys
.env
.env.local
.env.development
.env.production
cypress.env.json


# ============================================================
# OPERATING SYSTEM FILES
# ============================================================

# Mac system files
.DS_Store
.AppleDouble
.LSOverride

# Linux system files
*~

# Windows system files
Thumbs.db
Desktop.ini


# ============================================================
# VS CODE
# ============================================================

# VS Code editor settings — optional, some teams share these, most don't
.vscode/


# ============================================================
# LOGS
# ============================================================

logs/
*.log